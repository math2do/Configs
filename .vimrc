set number
set relativenumber
set tabstop=2        " Show tab character as 2 spaces
set mouse=a
set autoindent
set expandtab        " Use spaces instead of tabs
colorscheme evening
set shiftwidth=2     " Indent by 2 spaces when using >>, <<
set softtabstop=2    " Insert 2 spaces when pressing Tab
inoremap jj <Esc>
